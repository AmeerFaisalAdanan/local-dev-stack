# ==========================================
# Docker & Containers
# ==========================================
# Avoid committing local environment overrides
docker-compose.override.yml

# Ignore temporary build logs and contexts
.dockerignore
#!.dockerignore # Uncomment if you want to force-track the main .dockerignore

# Container volumes & persistent data
# (Prevents local database data or uploads from entering the repo)
*-data/

# ==========================================
# Secrets, Credentials, & Environment Files
# ==========================================
# NEVER commit raw credentials or environment variables
.env
.env.local
.env.*.local
*.env

# Docker secrets / keys
*.key
*.pem
.docker/config.json

# ==========================================
# Logs and Diagnostics
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# IDEs and OS Files
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
